{
  "manifest_version": 3,
  "name": "文章同步助手",
  "description": "基于爱贝壳内容同步流程的多平台文章发布包生成 Chrome 扩展。",
  "version": "0.1.0",
  "action": {
    "default_title": "文章同步助手",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://api.twitterapi.io/*",
    "https://api.bilibili.com/*",
    "https://*.bilibili.com/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
