{
  "manifest_version": 3,
  "name": "Viral Topic Finder",
  "description": "基于 kangarooking viral-topic 工作流的跨平台爆款选题 Chrome 扩展。",
  "version": "0.1.0",
  "action": {
    "default_title": "Viral Topic Finder",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "https://api.twitterapi.io/*",
    "https://api.bilibili.com/*",
    "https://*.bilibili.com/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
