{
  "manifest_version": 3,
  "name": "爱贝壳内容同步助手",
  "version": "1.0.0",
  "description": "一键全网分发，自媒体人的效率神器",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png",
    "256": "icons/icon-256.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icons/icon-128.png",
    "default_title": "爱贝壳内容同步助手"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ]
}
